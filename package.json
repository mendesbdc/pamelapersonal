{
  "name": "pamelapersonal",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run api\" \"vite\"",
    "api": "node api/server.mjs",
    "db:setup": "node scripts/setup-db.mjs",
    "prebuild": "node scripts/strip-public-apk.mjs",
    "brand:logo": "node scripts/process-brand-logo.mjs",
    "clean:dist": "node scripts/clean-dist.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "android:add": "npx cap add android",
    "android:sync": "node scripts/ensure-vite-api-url.mjs && npm run build && npx cap sync android",
    "android:open": "npm run android:sync && npx cap open android",
    "android:apk": "npm run android:sync && node scripts/android-gradle.cjs",
    "ios:sync": "node scripts/ensure-vite-api-url.mjs && npm run build && npx cap sync ios",
    "ios:open": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "bcryptjs": "^3.0.2",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.22.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "~5.7.2",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "sharp": "^0.34.5"
  }
}
